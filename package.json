{
	"name": "@akhil-saxena/design-system",
	"version": "1.8.0",
	"type": "module",
	"description": "Accessible React primitives with semantic tokens",
	"license": "MIT",
	"author": "Akhil Saxena <saxena.akhil42@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/akhil-saxena/design-system.git"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org",
		"access": "public"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist", "README.md", "LICENSE"],
	"sideEffects": ["*.css"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./hooks": {
			"types": "./dist/hooks/index.d.ts",
			"import": "./dist/hooks/index.js"
		},
		"./icons": {
			"types": "./dist/icons/index.d.ts",
			"import": "./dist/icons/index.js"
		},
		"./tokens.css": "./dist/tokens.css",
		"./primitives.css": "./dist/primitives.css",
		"./utilities.css": "./dist/utilities.css"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:visual": "playwright test",
		"test:visual:update": "playwright test --update-snapshots",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"check": "biome check .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"prepare": "is-ci || husky",
		"prepublishOnly": "npm run build && npm test"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@fontsource-variable/newsreader": "^5.2.10",
		"@fontsource/archivo": "^5.0.0",
		"@fontsource/inter": "^5.0.0",
		"@fontsource/jetbrains-mono": "^5.0.0",
		"@tiptap/extension-code-block-lowlight": "^3.22.5",
		"@tiptap/extension-highlight": "^3.22.5",
		"@tiptap/extension-link": "^3.22.5",
		"@tiptap/extension-placeholder": "^3.22.5",
		"@tiptap/extension-underline": "^3.22.5",
		"@tiptap/pm": "^3.22.5",
		"@tiptap/react": "^3.22.5",
		"@tiptap/starter-kit": "^3.22.5",
		"lowlight": "^3.3.0",
		"lucide-react": "^1.14.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@playwright/test": "^1.59.1",
		"@storybook/addon-essentials": "^8.6.14",
		"@storybook/preview-api": "^8.6.18",
		"@storybook/react-vite": "^8.6.18",
		"@storybook/test-runner": "^0.23.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^4.3.4",
		"@vitest/coverage-v8": "^4.1.4",
		"husky": "^9.1.7",
		"is-ci": "^4.1.0",
		"jsdom": "^25.0.1",
		"lint-staged": "^15.5.2",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"start-server-and-test": "^2.1.5",
		"storybook": "^8.6.18",
		"tsup": "^8.4.0",
		"typescript": "~6.0.2",
		"vitest": "^4.1.4"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,jsonc,css}": ["biome check --write --no-errors-on-unmatched"]
	},
	"engines": {
		"node": ">=20"
	}
}
